# LF endings on Linux-targeted files. Without this, Windows clones convert
# entrypoint scripts and Dockerfiles to CRLF, and the Linux container build
# crashloops with `/bin/sh^M: not found`. Per binarybeachio convention
# `feedback_fork_repo_lf_pin`.
*               text=auto eol=lf
*.sh            text eol=lf
*.bash          text eol=lf
*.j2            text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.json          text eol=lf
*.ts            text eol=lf
*.tsx           text eol=lf
*.js            text eol=lf
*.cjs           text eol=lf
*.mjs           text eol=lf
*.prisma        text eol=lf
*.sql           text eol=lf
*.toml          text eol=lf
*.md            text eol=lf
Dockerfile*     text eol=lf
*.dockerfile    text eol=lf
.env*           text eol=lf

# Treat lock files as generated to keep diffs sane.
pnpm-lock.yaml  -diff linguist-generated=true
package-lock.json -diff linguist-generated=true

# Binary assets — never normalize.
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.woff          binary
*.woff2         binary
*.ttf           binary
*.eot           binary
*.pdf           binary
